  "url": "https://api.tdameritrade.com/v2",
  "provider": {
    "@type": "Organization",
    "name": "TD Ameritrade",
    "url": "https://developer.tdameritrade.com/",
    "sameAs": "https://www.tdameritrade.com"
  },
  "documentation": "https://developer.tdameritrade.com/apis",
  "endpointUrl": "https://api.tdameritrade.com/v2",
  "offers": {
    "@type": "Offer",
    "category": "Financial Data / Brokerage API"
  },
  "potentialAction": [
    {
      "@type": "Action",
      "name": "Cancel Order",
      "description": "Cancel a specific order for a specific account. ",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "DELETE",
        "urlTemplate": "https://api.tdameritrade.com/v2/accounts/{accountId}/orders/{orderId}"
      }
    },
    {
      "@type": "Action",
      "name": "Replace Order",
      "description": "Replace an existing order for an account. The existing order will be replaced by the new order. Once replaced, the old order will be canceled and a new order will be created.",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "PUT",
        "urlTemplate": "https://api.tdameritrade.com/v2/accounts/{accountId}/orders/{orderId}"
      }
    },
    {
      "@type": "Action",
      "name": "Get Order",
      "description": "Get a specific order for a specific account.",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "GET",
        "urlTemplate": "https://api.tdameritrade.com/v2/accounts/{accountId}/orders/{orderId}"
      }
    },
    {
      "@type": "Action",
      "name": "Get Orders By Path",
      "description": "Orders for a specific account.",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "GET",
        "urlTemplate": "https://api.tdameritrade.com/v2/accounts/{accountId}/orders"
      }
    },
    {
      "@type": "Action",
      "name": "Place Order",
      "description": "Place an order for a specific account.",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "POST",
        "urlTemplate": "https://api.tdameritrade.com/v2/accounts/{accountId}/orders"
      }
    },
    {
      "@type": "Action",
      "name": "Get Orders By Query",
      "description": "All orders for a specific account or, if account ID isn't specified, orders will be returned for all linked accounts",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "GET",
        "urlTemplate": "https://api.tdameritrade.com/v2/orders"
      }
    },
    {
      "@type": "Action",
      "name": "Get Saved Orders by Path",
      "description": "Saved orders for a specific account.",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "GET",
        "urlTemplate": "https://api.tdameritrade.com/v2/accounts/{accountId}/savedorders"
      }
    },
    {
      "@type": "Action",
      "name": "Create Saved Order",
      "description": "Save an order for a specific account. ",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "POST",
        "urlTemplate": "https://api.tdameritrade.com/v2/accounts/{accountId}/savedorders"
      }
    },
    {
      "@type": "Action",
      "name": "Delete Saved Order",
      "description": "Delete a specific saved order for a specific account.",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "DELETE",
        "urlTemplate": "https://api.tdameritrade.com/v2/accounts/{accountId}/savedorders/{savedOrderId}"
      }
    },
    {
      "@type": "Action",
      "name": "Get Saved Order",
      "description": "Specific saved order by its ID, for a specific account.",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "GET",
        "urlTemplate": "https://api.tdameritrade.com/v2/accounts/{accountId}/savedorders/{savedOrderId}"
      }
    },
    {
      "@type": "Action",
      "name": "Replace Saved Order",
      "description": "Replace an existing saved order for an account. The existing saved order will be replaced by the new order.",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "PUT",
        "urlTemplate": "https://api.tdameritrade.com/v2/accounts/{accountId}/savedorders/{savedOrderId}"
      }
    },
    {
      "@type": "Action",
      "name": "Get Account",
      "description": "Account balances, positions, and orders for a specific account.",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "GET",
        "urlTemplate": "https://api.tdameritrade.com/v2/accounts/{accountId}"
      }
    },
    {
      "@type": "Action",
      "name": "Get Accounts",
      "description": "Account balances, positions, and orders for a specific account.",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "GET",
        "urlTemplate": "https://api.tdameritrade.com/v2/accounts"
      }
    },
    {
      "@type": "Action",
      "name": "Post Access Token",
      "description": "The token endpoint returns an access token along with an optional refresh token.",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "POST",
        "urlTemplate": "https://api.tdameritrade.com/v2/oath2/token"
      }
    },
    {
      "@type": "Action",
      "name": "Search for instrument and fundamental data",
