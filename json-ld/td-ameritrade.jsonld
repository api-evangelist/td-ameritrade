      "target": {
        "@type": "EntryPoint",
        "httpMethod": "GET",
        "urlTemplate": "https://api.tdameritrade.com/v2/marketdata/hours"
      }
    },
    {
      "@type": "Action",
      "name": "Operating hours of markets",
      "description": "Retrieve market hours for specified single market",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "GET",
        "urlTemplate": "https://api.tdameritrade.com/v2/marketdata/{market}/hours"
      }
    },
    {
      "@type": "Action",
      "name": "Retrieve mover information by index symbol, direction type and change",
      "description": "Top 10 (up or down) movers by value or percent for a particular market",
      "target": {
        "@type": "EntryPoint",
        "httpMethod": "GET",
        "urlTemplate": "https://api.tdameritrade.com/v2/marketdata/{index}/movers"
      }
    },
    {
