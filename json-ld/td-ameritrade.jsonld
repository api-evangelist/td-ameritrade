      "target": {
        "@type": "EntryPoint",
        "httpMethod": "GET",
        "urlTemplate": "https://api.tdameritrade.com/v2/marketdata/quotes"
      }
    },
    {
      "@type": "Action",
      "name": "APIs to access transaction history on the account",
