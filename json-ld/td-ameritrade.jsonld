      "target": {
        "@type": "EntryPoint",
        "httpMethod": "GET",
        "urlTemplate": "https://api.tdameritrade.com/v2/accounts/{accountId}/transactions/{transactionId}"
      }
    },
    {
      "@type": "Action",
